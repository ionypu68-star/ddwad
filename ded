local function createBeam(p1, p2)
    local distance = (p1 - p2).Magnitude
    if distance < 0.05 then return end
    local trace = Instance.new("Part")
    trace.Name = "BulletTrace"
    trace.Anchored = true; trace.CanCollide = false; trace.CanQuery = false; trace.CastShadow = false
    trace.Material = Enum.Material.ForceField
    trace.Transparency = TracerSettings.Transparency
    trace.Color = TracerSettings.Rainbow and Color3.fromHSV(tick()%5/5,1,1) or TracerSettings.Color
    trace.Size = Vector3.new(TracerSettings.Thickness, TracerSettings.Thickness, distance)
    trace.CFrame = CFrame.new(p1:Lerp(p2,0.5), p2)
    trace.Parent = workspace
    task.delay(TracerSettings.Lifetime, function() if trace then trace:Destroy() end end)
end

local function v413(v410)
    for _, v412 in ipairs(v408) do if v412 == v410 then return true end end
    return false
end

local function v419(v414)
    for _, v416 in ipairs(workspace:GetChildren()) do
        if v416:IsA("Model") then
            for _, v418 in ipairs(v416:GetDescendants()) do
                if v418:IsA("BasePart") and v413(v418.Material) then
                    if v414 then
                        if v409[v418] == nil then v409[v418] = v418.Transparency end
                        v418.Transparency = xrayTransparency
                    elseif v409[v418] ~= nil then
                        v418.Transparency = v409[v418]
                        v409[v418] = nil
                    end
                end
            end
        end
    end
end

local function scanForVehicles()
    if tick() - vehicleSettings.lastScan < 2 then return end
    vehicleSettings.lastScan = tick()
    vehicleSettings.activeVehicles = {}
    for _, obj in ipairs(workspace:GetDescendants()) do
        if obj:IsA("Model") then
            local hasSeat = obj:FindFirstChildWhichIsA("VehicleSeat")
            local isLikelyVehicle = obj:FindFirstChild("Body") or obj:FindFirstChild("Main") or obj.Name:match("Car") or obj.Name:match("Vehicle")
            if hasSeat or isLikelyVehicle then
                local mainPart = obj.PrimaryPart or obj:FindFirstChild("Body") or obj:FindFirstChildWhichIsA("BasePart", true)
                if mainPart then
                    table.insert(vehicleSettings.activeVehicles, { model = obj, mainPart = mainPart, seat = hasSeat })
                end
            end
        end
    end
end

local function applyStabilization(mainPart)
    if not vehicleSettings.stabilize then return end
    local currentCF = mainPart.CFrame
    local lookVector = currentCF.LookVector
    mainPart.CFrame = CFrame.new(currentCF.Position, currentCF.Position + Vector3.new(lookVector.X, 0, lookVector.Z))
end

local function isCandidate(m)
    return m:IsA("Model") and (m:FindFirstChild("HumanoidRootPart") or m:FindFirstChild("Head"))
end

local function applyToModel(m, state)
    local highlight = m:FindFirstChild("HighlightChams")
    if state then
        if not highlight then
            highlight = Instance.new("Highlight")
            highlight.Name = "HighlightChams"
            highlight.Parent = m
        end
        local colorToUse = Chams.rainbow and Color3.fromHSV(tick()%5/5,1,1) or Chams.color
        highlight.Enabled = true
        highlight.FillColor = colorToUse
        highlight.OutlineColor = Chams.outline
        highlight.DepthMode = Chams.depthMode
        highlight.FillTransparency = 0.5
        for _, p in ipairs(m:GetDescendants()) do
            if p:IsA("BasePart") then
                if not original[p] then original[p] = {Material = p.Material, Color = p.Color} end
                if p.Material ~= Chams.material then p.Material = Chams.material end
                if p.Color ~= colorToUse then p.Color = colorToUse end
            end
        end
    else
        if highlight then highlight.Enabled = false end
        for _, p in ipairs(m:GetDescendants()) do
            if p:IsA("BasePart") and original[p] then
                p.Material = original[p].Material
                p.Color = original[p].Color
                original[p] = nil
            end
        end
    end
end

local function track(m)
    if not m or tracked[m] or m == Player.Character then return end
    tracked[m] = true
end

