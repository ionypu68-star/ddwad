-- ============ SPEEDHACK (ИСПРАВЛЕННЫЙ) ============
local speedhack = {
    enabled = false,
    silent = false,
    silentActive = false,
    speed = 60,
    downcliff = false,
    downcliffAccel = 50,
    downcliffFall = 10,
    jetpack = false,
    jetpackUp = 10,
    jetpackDown = 0,
    forcesprint = false,
}

local function getCharParts()
    if not workspace.Const or not workspace.Const.Ignore or not workspace.Const.Ignore.LocalCharacter then
        return nil, nil, nil
    end
    local char = workspace.Const.Ignore.LocalCharacter
    return char:FindFirstChild("Middle"), char:FindFirstChild("Bottom"), char:FindFirstChild("Top")
end

local speedVars = {niga = 60, wtf = 0, nigasilent = 80, wtfsilent = 0, heightDevi = 2, dcBuildup = 60, slidin = false}

RunService.Heartbeat:Connect(function(delta)
    local middle, bottom, top = getCharParts()
    if not middle then return end

    local shift = UserInputService:IsKeyDown(Enum.KeyCode.LeftShift)
    local ctrl = UserInputService:IsKeyDown(Enum.KeyCode.C)
    local space = UserInputService:IsKeyDown(Enum.KeyCode.Space)
    local direction = Vector3.zero
    local camLook = workspace.CurrentCamera.CFrame.LookVector
    camLook = Vector3.new(camLook.X, 0, camLook.Z).Unit

    if UserInputService:IsKeyDown(Enum.KeyCode.W) then direction = direction + camLook end
    if UserInputService:IsKeyDown(Enum.KeyCode.S) then direction = direction - camLook end
    if UserInputService:IsKeyDown(Enum.KeyCode.D) then direction = direction + Vector3.new(-camLook.Z, 0, camLook.X) end
    if UserInputService:IsKeyDown(Enum.KeyCode.A) then direction = direction + Vector3.new(camLook.Z, 0, -camLook.X) end
    if direction ~= Vector3.zero then direction = direction.Unit end

    -- Silent speed
    if speedhack.silent and speedhack.silentActive then
        if speedVars.heightDevi > 0 then
            speedVars.nigasilent = math.clamp(speedVars.nigasilent - delta*20, 17, speedhack.speed)
        else
            speedVars.nigasilent = math.clamp(speedVars.nigasilent - delta*150, 17, speedhack.speed)
        end
        speedVars.heightDevi = speedVars.wtfsilent < 0.85 and 2 or math.clamp(speedVars.heightDevi - delta*15, 0, 3)
        if speedVars.wtfsilent == 0 then
            speedVars.slidin = true
            speedVars.nigasilent = speedhack.speed
        end
        local oldM, oldB, oldT = middle.CFrame, bottom.CFrame, top.CFrame
        middle.CFrame = oldM + Vector3.new(0, speedVars.heightDevi, 0)
        if bottom then bottom.CFrame = oldB + Vector3.new(0, speedVars.heightDevi, 0) end
        if top then top.CFrame = oldT + Vector3.new(0, speedVars.heightDevi, 0) end
        task.wait()
        if middle then middle.CFrame = oldM end
        if bottom then bottom.CFrame = oldB end
        if top then top.CFrame = oldT end
        middle.AssemblyLinearVelocity = direction * speedVars.nigasilent
        if top then top.AssemblyLinearVelocity = direction * speedVars.nigasilent end
        if bottom then bottom.AssemblyLinearVelocity = direction * speedVars.nigasilent end
        speedVars.wtfsilent = speedVars.wtfsilent + delta
        if speedVars.wtfsilent > 1.5 then
            speedVars.slidin = false
            speedVars.wtfsilent = 0
        end
        return
    end

    -- Обычный спидхак
    if speedhack.enabled and not speedhack.silent and middle and ctrl and shift then
        if direction ~= Vector3.zero then direction = direction.Unit end
        speedVars.niga = math.clamp(speedVars.niga - delta*20, 17, speedhack.speed)
        if speedVars.wtf == 0 then
            local tp, md, bt = top.CFrame, middle.CFrame, bottom.CFrame
            middle.CFrame = md + Vector3.new(0, 2, 0)
            if bottom then bottom.CFrame = bt + Vector3.new(0, 2, 0) end
            if top then top.CFrame = tp + Vector3.new(0, 2, 0) end
        end
        local yVel = speedVars.wtf < 0.85 and 0 or -7
        middle.AssemblyLinearVelocity = Vector3.new(direction.X * speedVars.niga, yVel, direction.Z * speedVars.niga)
        if bottom then bottom.AssemblyLinearVelocity = Vector3.new(direction.X * speedVars.niga, yVel, direction.Z * speedVars.niga) end
        if top then top.AssemblyLinearVelocity = Vector3.new(direction.X * speedVars.niga, yVel, direction.Z * speedVars.niga) end
        speedVars.wtf = speedVars.wtf + delta
    elseif speedhack.downcliff and middle and ctrl and shift then
        if direction ~= Vector3.zero then direction = direction.Unit end
        if space and speedVars.wtf == 0 then
            local tp, md, bt = top.CFrame, middle.CFrame, bottom.CFrame
            middle.CFrame = md + Vector3.new(0, 2, 0)
            if bottom then bottom.CFrame = bt + Vector3.new(0, 2, 0) end
            if top then top.CFrame = tp + Vector3.new(0, 2, 0) end
            speedVars.wtf = speedVars.wtf + delta
        end
        speedVars.dcBuildup = math.clamp(space and speedVars.dcBuildup - delta*25 or speedVars.dcBuildup + delta*speedhack.downcliffAccel, 17, 25)
        local yVel = space and -7 or -speedhack.downcliffFall
        middle.AssemblyLinearVelocity = Vector3.new(direction.X * speedVars.dcBuildup, yVel, direction.Z * speedVars.dcBuildup)
        if bottom then bottom.AssemblyLinearVelocity = Vector3.new(direction.X * speedVars.dcBuildup, yVel, direction.Z * speedVars.dcBuildup) end
        if top then top.AssemblyLinearVelocity = Vector3.new(direction.X * speedVars.dcBuildup, yVel, direction.Z * speedVars.dcBuildup) end
    elseif speedhack.jetpack and middle then
        if direction ~= Vector3.zero then direction = direction.Unit end
        local yvel = space and speedhack.jetpackUp or shift and -speedhack.jetpackDown or 0
        middle.AssemblyLinearVelocity = Vector3.new(direction.X * 18, yvel, direction.Z * 18)
        if top then top.AssemblyLinearVelocity = Vector3.new(direction.X * 18, yvel, direction.Z * 18) end
        if bottom then bottom.AssemblyLinearVelocity = Vector3.new(direction.X * 18, yvel, direction.Z * 18) end
    elseif speedhack.forcesprint and middle then
        if direction ~= Vector3.zero then direction = direction.Unit end
        middle.AssemblyLinearVelocity = Vector3.new(direction.X * 18, middle.AssemblyLinearVelocity.Y, direction.Z * 18)
    else
        speedVars.niga = speedhack.speed
        speedVars.dcBuildup = 10
        speedVars.wtf = 0
    end
end)

